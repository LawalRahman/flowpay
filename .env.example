# FlowPay Environment Configuration

## Stellar Network Configuration
# Network: testnet or public
STELLAR_NETWORK=testnet

# RPC Endpoint URL
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-mainnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Network Passphrase
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

## Smart Contract Addresses
# These are populated after contract deployment
# Testnet contract addresses (example format: CABC123...)
PAYMENT_CHANNEL_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF
ESCROW_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF
MERCHANT_REGISTRY_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF
RECURRING_PAYMENT_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF

## Backend Wallet Configuration
# Admin wallet secret key for backend operations
# WARNING: Never commit real secret keys to version control
# Use: soroban keys generate flowpay --network testnet
BACKEND_SECRET_KEY=SBBB1234567890ABCDEF1234567890ABCDEF

## Test Wallets (Development Only)
# Generate with: soroban keys generate test-user-1 --network testnet
# Fund with: https://laboratory.stellar.org/#account-creator?network=testnet
TEST_WALLET_1_SECRET=SBBB1111111111111111111111111111111
TEST_WALLET_2_SECRET=SBBB2222222222222222222222222222222
TEST_WALLET_3_SECRET=SBBB3333333333333333333333333333333

## Database Configuration
# PostgreSQL connection string for event persistence
DATABASE_URL=postgresql://flowpay:flowpay_pass@localhost:5432/flowpay_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=flowpay
DATABASE_PASSWORD=flowpay_pass
DATABASE_NAME=flowpay_db

## Backend API Configuration
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# CORS configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

## Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=logs/backend.log

## Frontend Configuration
REACT_APP_API_URL=http://localhost:3000
REACT_APP_NETWORK=testnet

# Contract IDs for frontend
REACT_APP_PAYMENT_CHANNEL_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF
REACT_APP_ESCROW_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF
REACT_APP_MERCHANT_REGISTRY_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF
REACT_APP_RECURRING_PAYMENT_CONTRACT_ID=CABC1234567890ABCDEF1234567890ABCDEF

## Feature Flags
ENABLE_EVENT_STREAMING=true
ENABLE_TEST_ENDPOINTS=true
ENABLE_CONTRACT_DEPLOYMENT_HELPER=true

## Service Configuration
# RPC connection timeout (ms)
RPC_TIMEOUT=30000

# Event listener polling interval (ms)
EVENT_LISTENER_INTERVAL=10000

# Transaction submission retry attempts
TX_RETRY_ATTEMPTS=3

# Transaction confirmation timeout (ms)
TX_CONFIRMATION_TIMEOUT=300000

## Monitoring & Telemetry
SENTRY_DSN=
TELEMETRY_ENABLED=false

## Payment Configuration
# Default asset address (native Stellar lumens)
DEFAULT_ASSET_ADDRESS=native

# Fee calculation parameters
BASE_FEE_STROOPS=100
OPERATION_FEE_STROOPS=100

## Security
# JWT configuration (for future auth)
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=7d

# HTTPS/SSL (for production)
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

## Development Tools
# Enable Swagger API documentation
SWAGGER_ENABLED=true

# Enable contract deployment helpers
CONTRACT_DEPLOYMENT_MODE=manual

## Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@flowpay.io
SMTP_PASSWORD=
NOTIFICATION_EMAIL=admin@flowpay.io

## Blockchain Network Settings
# Network timeout for Stellar operations
STELLAR_TIMEOUT=60000

# Transaction fee multiplier (for high network load)
FEE_MULTIPLIER=1.0

## Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600

## File Storage (for contract uploads, etc.)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Alternative: S3 configuration
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=flowpay-contracts
# AWS_REGION=us-east-1

## Notification Webhook
# Post transaction events to external systems
WEBHOOK_URL=
WEBHOOK_SECRET=

## Debug Mode
DEBUG=flowpay:*

## Contract Compilation Settings (Rust)
RUST_BACKTRACE=1
CARGO_TARGET_DIR=./target
