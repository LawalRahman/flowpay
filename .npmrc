# NPM Configuration for consistent behavior across environments

# Use exact versions from lockfile for reproducible installs
# This ensures Netlify builds match local development
save-exact=false

# Enable offline mode checking (useful for CI/CD)
offline=false

# Set strict SSL validation (recommended for security)
strict-ssl=true

# Prefer using yarn when available (monorepo support)
# Yarn workspaces are defined in package.json

# Registry configuration
# Using default npm registry
# For private packages, add: @myorg:registry=https://registry.example.com

# Audit configuration
# Audit dev dependencies as well
audit-level=low

# Log output
# Set to 'warn' for cleaner output in CI/CD pipelines
loglevel=warn
