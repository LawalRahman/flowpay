# Yarn Configuration for FlowPay project

# Enable offline mode for monorepo support
# yarn-offline-mirror false

# Disable creating a flat node_modules structure
# We want dependencies properly nested for monorepo workspaces
flat false

# Network timeout in milliseconds (default: 30000)
network-timeout 30000

# Use existing lockfile if available
prefer-offline true

# Ignore scripts from dependencies during install
ignore-scripts false

# Enable yarn workspaces support (monorepo)
workspaces-experimental true

# Verbose logging
verbose false
